DISCORD_BOT_TOKEN=your-bot-token-here
# Optional: comma-separated Discord user IDs allowed to send commands
DISCORD_ALLOWED_USERS=
# Optional: defaults to routes.json in this folder
ROUTES_FILE=routes.json
# Optional: defaults to .data in this folder
DATA_DIR=.data
# Optional: defaults to .data/audit.log.jsonl in this folder
AUDIT_LOG_FILE=.data/audit.log.jsonl
# Optional: default 24
SESSION_TTL_HOURS=24
# Optional: default 15
APPROVAL_TTL_MINUTES=15
# Optional: true/false, default false
MAINTENANCE_MODE=false
# Optional: comma-separated admin user IDs for maintenance toggles
MAINTENANCE_ALLOW_USERS=
# Optional message shown when maintenance blocks requests
MAINTENANCE_MESSAGE=Maintenance mode enabled. New requests are temporarily paused.