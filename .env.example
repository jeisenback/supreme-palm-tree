# Copy this to .env (DO NOT COMMIT .env with real credentials)
# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-2

# Google Drive (optional)
GDRIVE_CREDENTIAL_TYPE=service_account
GDRIVE_CREDENTIALS=
GDRIVE_FOLDER_ID=

# Scheduler
SCHEDULER_JOBSTORE=sqlite:///./scheduler_jobs.sqlite
SCHEDULER_METRICS_PORT=0
